# Copy this file to .env and fill in the values

# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# JWT secret — any long random string (e.g. run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=change_me_to_a_long_random_string

# PostgreSQL connection string
# Local:    postgresql://postgres:password@localhost:5432/foodlogger
# Railway:  provided automatically via $DATABASE_URL env variable
DATABASE_URL=postgresql://postgres:password@localhost:5432/foodlogger

# Server port (Railway sets this automatically)
PORT=3000

# Set to "production" on Railway
NODE_ENV=development
